<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         processIsolation="false"
         stopOnFailure="false"
         executionOrder="depends,defects"
         failOnWarning="true"
         failOnRisky="true"
         failOnEmptyTestSuite="true"
         beStrictAboutOutputDuringTests="true"
         cacheDirectory=".phpunit.cache"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    
    <source>
        <include>
            <directory>app</directory>
        </include>
        <exclude>
            <directory>app/Console/Kernel.php</directory>
            <directory>app/Exceptions/Handler.php</directory>
            <directory>app/Http/Middleware</directory>
            <file>app/Providers/RouteServiceProvider.php</file>
        </exclude>
    </source>
    
    <coverage includeUncoveredFiles="true"
              ignoreDeprecatedCodeUnits="true"
              disableCodeCoverageIgnore="true">
        <report>
            <html outputDirectory="build/coverage"/>
            <text outputFile="build/coverage.txt"/>
            <clover outputFile="build/logs/clover.xml"/>
        </report>
    </coverage>
    
    <php>
        <!-- Test Environment - Isolated from Development -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_KEY" value="base64:2fl+Ktvkdphvz9JfhiJdD3F6XgOQmAFWwEC4qyaqr30=" force="true"/>
        <env name="APP_DEBUG" value="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        
        <!-- MySQL Test Database - Separate from Development -->
        <env name="DB_CONNECTION" value="mysql" force="true"/>
        <env name="DB_HOST" value="127.0.0.1" force="true"/>
        <env name="DB_PORT" value="3306" force="true"/>
        <env name="DB_DATABASE" value="josecamejo_test" force="true"/>
        <env name="DB_USERNAME" value="root" force="true"/>
        <env name="DB_PASSWORD" value="" force="true"/>
        
        <!-- Use array drivers for caching, sessions - Isolated -->
        <env name="CACHE_STORE" value="array"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        
        <!-- Fast hashing for tests -->
        <env name="BCRYPT_ROUNDS" value="4"/>
        
        <!-- Logging -->
        <env name="LOG_CHANNEL" value="single"/>
        <env name="LOG_LEVEL" value="critical"/>
        <env name="BROADCAST_DRIVER" value="log"/>
        
        <!-- Mail -->
        <env name="MAIL_MAILER" value="array"/>
        
        <!-- Filesystems -->
        <env name="FILESYSTEM_DISK" value="local"/>
        
        <!-- Disable heavy services -->
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        
        <!-- Performance settings -->
        <ini name="memory_limit" value="512M"/>
        <ini name="max_execution_time" value="0"/>
    </php>
</phpunit>
